{
  "version": 2,
  "builds": [
    {
      "src": "api-server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/api$",
      "dest": "api-server.js"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "api-server.js"
    },
    {
      "src": "^/contact$",
      "dest": "Contact.html"
    },
    {
      "src": "^/blog$",
      "dest": "blog.html"
    },
    {
      "src": "^/admin-login$",
      "dest": "admin-login.html"
    },
    {
      "src": "^/admin-dashboard$",
      "dest": "admin-dashboard.html"
    },
    {
      "src": "^/sitemap\\.xml$",
      "dest": "sitemap.xml"
    },
    {
      "src": "^/$",
      "dest": "index.html"
    },
    {
      "src": "^/robots\\.txt$",
      "dest": "robots.txt"
    },
    {
      "src": "/.*",
      "dest": "404.html"
    }
  ],
  "env": {
    "MONGODB_URI": "mongodb_uri",
    "ADMIN_EMAIL": "admin_email",
    "ADMIN_PASSWORD": "admin_password",
    "JWT_SECRET": "jwt_secret",
    "CORS_ORIGIN": "https://velvetnocturne.shop",
    "NODE_ENV": "production"
  }
}
